<%= block_component_edit :layout, horizontal: true %>
<hr class="my-4">
<div class="row">
  <div class="col-xl-6">
    <%= block_component_edit :description %>
    <%= block_component_add_element t('.add_image') %>
  </div>
  <div class="col-xl-6">
    <div class="card">
      <div class="card-header pb-0">
        <h2 class="card-title mb-0">Image en cours d'édition</h2>
      </div>
      <div class="card-body">
        <div v-show="!elementSelected">
          Cliquer sur une image ci-dessous pour l'éditer
        </div>
        <div v-show="elementSelected">
          <div class="row">
            <div class="col-lg-6">
              <%= block_component_edit :image, template: @element, model: 'currentElement' %>
            </div>
            <div class="col-lg-6">
              <%= block_component_edit :alt, template: @element, model: 'currentElement' %>
              <%= block_component_edit :credit, template: @element, model: 'currentElement' %>
              <%= block_component_edit :text, template: @element, model: 'currentElement' %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<draggable :list="data.elements" handle=".imageHandle" class="row">
  <div v-for="(element, index) in data.elements" class="col-xxl-2 col-lg-3 col-6">
    <div  class="card"
          v-on:click="elementSelected = true; currentElement = element">
      <div  class="card-header"
            v-bind:class="{ 'bg-dark' : element == currentElement }">
        <a class="btn ps-0 pt-0 imageHandle">
          <i class="fa fa-bars handle"></i>
        </a>
        <div class="float-end">
          <a  class="btn btn-sm btn-danger"
              v-on:click="data.elements.splice(data.elements.indexOf(element), 1)"
              title="<%= t '.remove_image' %>">
              <i class="fas fa-times"></i>
          </a>
        </div>
      </div>
      <img :src="getImageUrl(element.image)" class="img-fluid" v-if="element.image.id" />
      <div class="card-body" v-show="!element.image.id">
        <p>Cliquer ici pour éditer l'image</p>
      </div>
    </div>
  </div>
</draggable>
