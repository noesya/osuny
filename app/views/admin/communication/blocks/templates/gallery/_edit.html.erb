<a  class="<%= button_classes('mb-4') %>"
    v-on:click="data.elements.push({alt: '', file: {}, image: {}})">
    <%= t '.add_image' %>
</a>

<draggable :list="data.elements" handle=".imageHandle" class="row">
  <div v-for="(image, imageIndex) in data.elements" class="col-xxl-2 col-xl-3 col-md-4 col-6">
    <div class="card">
      <div class="card-header border-bottom">
        <a class="btn ps-0 pt-0 imageHandle">
          <i class="fa fa-bars handle"></i>
        </a>
        <div class="float-end">
          <a  class="btn btn-sm btn-danger"
              v-on:click="data.elements.splice(data.elements.indexOf(image), 1)"
              title="<%= t '.remove_image' %>">
              <i class="fas fa-times"></i>
          </a>
        </div>
      </div>

      <img :src="getImageUrl(image.file)" class="img-fluid d-block" v-if="image.file.id" />
      <div class="card-body">
        <%= render 'admin/communication/blocks/components/file-upload/edit',
            data: 'image.image' %>
          <label  aria-label="<%= t '.text_label' %>"
                  :for="'image-text-' + imageIndex">
                  <%= t '.text_label' %>
          </label>
          <textarea class="form-control"
                  v-model="image.text"
                  placeholder="<%= t '.text_placeholder' %>"
                  :id="'image-text-' + imageIndex"></textarea>
        </div>
      </div>
    </div>
  </div>
</draggable>
