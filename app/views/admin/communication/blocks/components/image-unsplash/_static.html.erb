<%
# Sometimes you want:
# image:
#   id: "b14f3c28-666a-477b-a69d-d75365aec898"
#   alt: >
#     Alternative text
#   credit: >
#     Credit
# And sometimes you want a list of that, with text not part of the :
# - image:
#     id: "dd4538dc-191f-4fc5-ad26-708e7155fd81"
#     alt: >
#       Alternative text
#     credit: >
#       Credit
#   text: >
#     This is the text

indent_depth ||= 3 # Default depth for direct properties
indent = '  ' * indent_depth
%>
<% if source %>
image:
<%= indent %>  id: "<%= source.blob.id %>"
<%= indent %>  alt: >
<%= indent %>    <%= prepare_text_for_static source.alt %>
<%= indent %>  credit: >
<%= indent %>    <%= prepare_text_for_static source.credit %>
<% end %>
