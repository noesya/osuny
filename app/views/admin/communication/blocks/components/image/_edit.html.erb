<%
root ||= 'data'
property ||= 'image'
title ||= ''
%>
<div v-if="!<%= root %>.<%= property %>.id">
  <label  class="form-label"
          for="<%= root %>.<%= property %>.id">
    <%= title %>
  </label>
  <input  class="form-control mb-2"
          type="file"
          accept="image/*"
          @change="onFileImageChange( $event, data.image, 'id' )"
          id="<%= root %>.<%= property %>.id">
</div>
<div v-if="data.image">
  <img :src="getImageUrl(<%= root %>.<%= property %>.id)"
        class="img-fluid mb-2"
        style="max-height: 80px"
        />
  <br>
  <a  class="btn btn-sm btn-danger mb-2"
      v-on:click="<%= root %>.<%= property %>.id=null">
      <i class="fas fa-times"></i>
      <%= t 'admin.communication.blocks.components.image.remove' %>
  </a>
</div>
<label  class="form-label"
        for="<%= property %>.alt">
  <%= t 'admin.communication.blocks.components.image.alt.label' %>
</label>
<input id="<%= property %>.alt"
        type="text"
        class="form-control mb-2"
        v-model="<%= root %>.<%= property %>.alt"
        placeholder="<%= t 'admin.communication.blocks.components.image.alt.label' %>" />
<label  class="form-label" for="<%= property %>.credit">
  <%= t 'admin.communication.blocks.components.image.credit.label' %>
</label>
<input  id="<%= property %>.credit"
        type="text"
        class="form-control"
        v-model="<%= root %>.<%= property %>.credit"
        placeholder="<%= t 'admin.communication.blocks.components.image.credit.placeholder' %>" />
